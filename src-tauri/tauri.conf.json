{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Glassbox",
  "version": "0.2.3",
  "identifier": "com.brianwestphal.glassbox",
  "build": {
    "beforeDevCommand": "npm run dev:server",
    "devUrl": "http://localhost:4183",
    "frontendDist": "loading"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Glassbox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/glassbox-node"
    ],
    "resources": [
      "server/**/*",
      "resources/glassbox",
      "resources/glassbox-linux",
      "resources/glassbox.cmd"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NUJDRUI2RjZBNUQ1NDMKUldSRDFhWDJ0czViNkR6QkpLUHVHOXVGaHQ1UUV6YzdsRUxKL1dTbGRkaUxYMkU2dkVDRFNKd00K",
      "endpoints": [
        "https://github.com/brianwestphal/glassbox/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
